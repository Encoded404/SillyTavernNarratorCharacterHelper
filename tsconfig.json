{
    "compilerOptions": {
        "target": "ES6",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "outDir": "./out",
        "strict": true,
        "esModuleInterop": true,
        "sourceMap": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "scripts/*": ["../SillyTavern/public/scripts/*"],
            "script.js": ["../SillyTavern/public/script.js"]
        }
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "globals.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "bin"
    ]
}